# =============================================================================
# Noteflow Testing Environment Template
# Domain: noteflowtest.jotoai.com
#
# 使用方法: 复制此文件为 .env，然后填入实际的测试环境值
#   cp .env.testing.example .env
#
# 标记说明:
#   [需填入] = 必须填入测试环境的实际值
#   [可选]   = 可以留空，功能会被禁用
#   [已配置] = 已有默认值，通常不需要修改
# =============================================================================

# Database (独立测试数据库) [已配置]
POSTGRES_USER=noteflow_test
POSTGRES_PASSWORD=noteflow_test_secret
POSTGRES_DB=noteflow_test
DATABASE_URL=postgresql+asyncpg://noteflow_test:noteflow_test_secret@postgres:5432/noteflow_test

# JWT [已配置]
JWT_SECRET_KEY=noteflow-testing-secret-t3s7k9m2p4x1q8
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Qwen API (Alibaba Cloud) [需填入]
QWEN_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Chat LLM [已配置]
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus
LLM_CONTEXT_WINDOW=256000
LLM_MAX_OUTPUT_TOKENS=16384

# Vision LLM [可选]
LLM_VISION_MODEL=glm-4.5v
LLM_VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_VISION_API_KEY=

# RAGFlow [可选]
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=

# MinerU [已配置]
MINERU_BASE_URL=http://mineru:8010

# File Storage [已配置]
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# Email (Resend) [需填入]
RESEND_API_KEY=re_xxx
APP_BASE_URL=https://noteflowtest.jotoai.com

# Admin [已配置]
ADMIN_EMAIL=admin@noteflowtest.jotoai.com

# Docmee (AI PPT) [可选]
DOCMEE_API_KEY=ak_xxx

# Google OAuth [可选]
GOOGLE_PROXY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://noteflowtest.jotoai.com/api/auth/google/callback

# Microsoft OAuth (Entra ID) [可选]
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://noteflowtest.jotoai.com/api/auth/microsoft/callback
