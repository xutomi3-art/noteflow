# Database
POSTGRES_USER=noteflow
POSTGRES_PASSWORD=noteflow_secret
POSTGRES_DB=noteflow
DATABASE_URL=postgresql+asyncpg://noteflow:noteflow_secret@postgres:5432/noteflow

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Primary LLM (local GPU — Qwen3.5-35B)
LLM_BASE_URL=http://10.200.0.102:8100/v1
LLM_MODEL=Qwen3.5-35B
LLM_CONTEXT_WINDOW=32768
QWEN_API_KEY=not-needed

# Backup LLM (cloud — Qwen3.5-Plus via Alibaba Cloud)
LLM_BACKUP_ENABLED=true
LLM_BACKUP_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BACKUP_MODEL=qwen3.5-plus
LLM_BACKUP_API_KEY=sk-xxx
LLM_BACKUP_CONTEXT_WINDOW=1000000

# Embedding (local GPU — BGE-M3, configured in RAGFlow)
QWEN_EMBEDDING_MODEL=BAAI/bge-m3

# RAGFlow
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=

# MinerU
MINERU_BASE_URL=http://mineru:8010

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
