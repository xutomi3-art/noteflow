# Database
POSTGRES_USER=noteflow
POSTGRES_PASSWORD=noteflow_secret
POSTGRES_DB=noteflow
DATABASE_URL=postgresql+asyncpg://noteflow:noteflow_secret@postgres:5432/noteflow

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Qwen API (Alibaba Cloud)
QWEN_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v3

# RAGFlow
RAGFLOW_BASE_URL=http://ragflow:9380
RAGFLOW_API_KEY=

# MinerU
MINERU_BASE_URL=http://mineru:8010

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
